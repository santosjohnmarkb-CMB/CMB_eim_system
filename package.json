{
  "name": "cmb-eim",
  "version": "1.0.0",
  "description": "CMB Equipment Inventory Management System",
  "main": "dist-main/main/index.js",
  "author": {
    "name": "CMB Film Services, Inc.",
    "email": "info@cmbfilmservices.com"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "npm run build:main && concurrently -k -n MAIN,RENDERER,ELECTRON -c blue,green,magenta \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "dev:electron": "nodemon",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "unset ELECTRON_RUN_AS_NODE && electron .",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@supabase/supabase-js": "^2.105.1",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "electron-store": "^8.2.0",
    "exceljs": "^4.4.0",
    "google-auth-library": "^9.15.1",
    "googleapis": "^144.0.0",
    "lucide-react": "^0.330.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "uuid": "^9.0.1",
    "ws": "^8.21.0",
    "zod": "^4.3.6",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.13.9",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.0.12",
    "wait-on": "^8.0.5"
  }
}
